{
  "name": "zinc",
  "version": "0.1.0",
  "description": "Cross-process shared memory for JavaScript — mmap-backed ArrayBuffers across Bun, Node.js, and Deno",
  "type": "module",
  "main": "./src/index.ts",
  "exports": {
    ".": {
      "bun": "./src/index.ts",
      "default": "./src/index.ts"
    }
  },
  "scripts": {
    "build": "bash scripts/build-all.sh",
    "bench": "bash scripts/bench.sh",
    "demo": "bash scripts/run-demo.sh",
    "test": "bun test tests/",
    "test:zig": "cd core && zig build test",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "typescript": "^5.4.0",
    "@types/node": "^20.0.0"
  },
  "keywords": [
    "zinc",
    "shared-memory",
    "mmap",
    "zero-copy",
    "cross-process",
    "arraybuffer",
    "bun",
    "deno",
    "nodejs",
    "cross-runtime",
    "ipc",
    "zig",
    "ffi",
    "napi",
    "performance"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/your-org/zinc"
  },
  "bugs": {
    "url": "https://github.com/your-org/zinc/issues"
  },
  "homepage": "https://github.com/your-org/zinc#readme",
  "engines": {
    "node": ">=20.0.0",
    "bun": ">=1.1.0"
  }
}
