{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "lib": ["ES2022"],
    "strict": true,
    "exactOptionalPropertyTypes": true,
    "noUncheckedIndexedAccess": true,
    "noImplicitReturns": true,
    "noFallthroughCasesInSwitch": true,
    "forceConsistentCasingInFileNames": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "outDir": "dist",
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true
  },
  "include": [
    "bun-ffi/**/*.ts",
    "deno-plugin/**/*.ts",
    "protocol/**/*.ts",
    "examples/**/*.ts",
    "tests/**/*.ts"
  ],
  "exclude": ["node_modules", "dist", "core/zig-out"]
}
