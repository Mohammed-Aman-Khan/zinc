{
  "name": "@uipc/node",
  "version": "0.1.0",
  "description": "Universal-IPC Bridge — Node.js native addon (Rust N-API)",
  "main": "index.js",
  "types": "index.d.ts",
  "napi": {
    "name": "uipc_node",
    "triples": {
      "defaults": true,
      "additional": [
        "x86_64-unknown-linux-musl",
        "aarch64-unknown-linux-gnu"
      ]
    }
  },
  "scripts": {
    "build": "napi build --platform --release",
    "build:debug": "napi build --platform",
    "artifacts": "napi artifacts",
    "prepublishOnly": "napi prepublish -t npm"
  },
  "devDependencies": {
    "@napi-rs/cli": "^2.18"
  },
  "license": "MIT",
  "engines": {
    "node": ">= 20"
  }
}
